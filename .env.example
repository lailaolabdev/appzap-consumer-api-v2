# AppZap Consumer API V2 - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/appzap_consumer_v2

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# POS V1 Integration (appzap-app-api) - Running on port 7070
# =============================================================================
# Base URL of POS V1 API
POS_V1_API_URL=http://localhost:7070

# API Key for POS V1 Consumer API endpoints
# FORMAT: appzap_pos_{live|test}_sk_{64-char-hex-secret}
#
# To generate this key, choose one of these methods:
# 1. Run script: cd appzap-app-api/api && node scripts/generateConsumerApiKey.js
# 2. API call: POST /v5/admin/api-keys/system with body:
#    { "name": "Consumer API V2", "preset": "consumer_app", "keyType": "system" }
#    (Requires admin authentication)
#
# Scopes granted by consumer_app preset:
# - read:all-restaurants, read:restaurant-details, read:menu, read:tables
# - write:reservations, read:all-reservations, write:orders, read:orders
# - consumer:search, consumer:book, consumer:profile
POS_V1_API_KEY=appzap_pos_live_sk_your_key_here

# =============================================================================
# POS V2 Integration (appzap-pos-api-v2) - Running on port 80
# =============================================================================
# Base URL of POS V2 API
POS_V2_API_URL=http://localhost:80

# API Key for POS V2 Consumer API endpoints
# FORMAT: appzap_pos_{live|test}_sk_{64-char-hex-secret}
#
# To generate this key:
# API call: POST /api/v1/api-keys with body:
# { "name": "Consumer API V2", "preset": "consumer_app", "keyType": "system" }
# (Requires admin authentication)
POS_V2_API_KEY=appzap_pos_live_sk_your_key_here

# =============================================================================
# External APIs
# =============================================================================
AUTH_API_URL=http://localhost:8080
SUPPLIER_API_URL=http://localhost:8081
SUPPLIER_EXCHANGE_KEY=

# =============================================================================
# Payment Gateway (PhaPay)
# =============================================================================
PHAPAY_MERCHANT_ID=
PHAPAY_SECRET_KEY=
PHAPAY_WEBHOOK_SECRET=
PHAPAY_API_URL=https://api.phapay.la

# =============================================================================
# Firebase Configuration (for push notifications)
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_API_KEY=
FIREBASE_DYNAMIC_LINK_DOMAIN=

# =============================================================================
# Storage (S3/MinIO)
# =============================================================================
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=

# =============================================================================
# Deep Link Configuration
# =============================================================================
DEEP_LINK_URL_SCHEME=appzap
DEEP_LINK_WEB_FALLBACK=https://app.appzap.la
DEEP_LINK_ANDROID_PACKAGE=com.appzap.consumer
DEEP_LINK_IOS_BUNDLE=com.appzap.consumer
