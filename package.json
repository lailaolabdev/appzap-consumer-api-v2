{
  "name": "appzap-consumer-api",
  "version": "1.0.0",
  "description": "AppZap Super App Consumer API - Production Ready",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production pm2 start dist/server.js -i max --name appzap-consumer-api",
    "test": "NODE_ENV=test jest --coverage",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:phase1": "NODE_ENV=test jest --testPathPattern=phase1 --verbose",
    "test:phase2": "NODE_ENV=test jest --testPathPattern=phase2 --verbose",
    "test:phase3": "NODE_ENV=test jest --testPathPattern=phase3 --verbose",
    "test:phase4": "NODE_ENV=test jest --testPathPattern=phase4 --verbose",
    "test:auth": "NODE_ENV=test jest --testPathPattern=auth.test --verbose",
    "test:cart": "NODE_ENV=test jest --testPathPattern=cart.test --verbose",
    "test:checkout": "NODE_ENV=test jest --testPathPattern=checkout.test --verbose",
    "test:orders": "NODE_ENV=test jest --testPathPattern=orders.test --verbose",
    "test:ci": "NODE_ENV=test jest --ci --coverage --maxWorkers=2",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "migrate": "ts-node src/scripts/migrate.ts"
  },
  "keywords": [
    "appzap",
    "super-app",
    "consumer-api",
    "laos",
    "restaurant",
    "food-delivery"
  ],
  "author": "AppZap Team",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "redis": "^4.6.11",
    "axios": "^1.6.2",
    "socket.io": "^4.6.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "rate-limit-redis": "^4.2.0",
    "express-validator": "^7.0.1",
    "bull": "^4.12.0",
    "node-cron": "^3.0.3",
    "compression": "^1.7.4",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "@sentry/node": "^7.91.0",
    "prom-client": "^15.1.0",
    "firebase-admin": "^12.0.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/compression": "^1.7.5",
    "@types/uuid": "^9.0.7",
    "@types/qrcode": "^1.5.5",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.0.1",
    "mongodb-memory-server": "^9.1.6"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}

